{
  "name": "@image2roblox/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "predev": "pnpm --filter @image2roblox/schemas build && pnpm --filter @image2roblox/shared build && pnpm --filter @image2roblox/agent-core build && pnpm --filter @image2roblox/roblox-generator build && pnpm --filter @image2roblox/ui build",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "rebuild:native": "electron-builder install-app-deps",
    "prepackage:win": "pnpm run build && pnpm run rebuild:native",
    "package:win": "electron-builder --win nsis"
  },
  "dependencies": {
    "@image2roblox/agent-core": "workspace:*",
    "@image2roblox/roblox-generator": "workspace:*",
    "@image2roblox/schemas": "workspace:*",
    "@image2roblox/shared": "workspace:*",
    "@image2roblox/ui": "workspace:*",
    "better-sqlite3": "^12.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.4",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4",
    "electron": "^37.3.1"
  },
  "build": {
    "appId": "com.image2roblox.builder",
    "productName": "Image2Roblox Builder",
    "directories": {
      "output": "out-installer"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "description": "Windows desktop app for generating Roblox starter worlds from a single image.",
  "author": "Image2Roblox Builder"
}
